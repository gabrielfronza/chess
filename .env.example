# API
NODE_ENV=development
APP_VERSION=0.1.0
PORT=3000
COMPOSE_PROJECT_NAME=chess_app
POSTGRES_PORT=54329
POSTGRES_USER=chess_app
POSTGRES_PASSWORD=chess_app_local
POSTGRES_DB=chess_app_dev
POSTGRES_TEST_DB=chess_app_test
DATABASE_URL=postgresql://chess_app:chess_app_local@localhost:54329/chess_app_dev
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
LICHESS_CLIENT_ID=
LICHESS_CLIENT_SECRET=
LICHESS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/lichess/callback
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mobile (public values only)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_AUTH0_DOMAIN=
EXPO_PUBLIC_AUTH0_CLIENT_ID=
