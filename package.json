{
  "name": "chess-tournament-platform",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22.13 <23"
  },
  "scripts": {
    "dev": "nx run-many -t serve --projects=api,mobile --parallel=2",
    "dev:mobile": "nx serve mobile",
    "dev:api": "nx serve api",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:unit": "nx run-many -t test --exclude=e2e",
    "test:e2e": "nx e2e e2e",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint-fix",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "husky": "^9.1.7",
    "nx": "^23.0.2",
    "prettier": "^3.9.5"
  }
}
